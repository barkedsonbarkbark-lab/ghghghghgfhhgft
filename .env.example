# Render OAuth relay for AuraBot
PORT=3000

# Discord OAuth2 app (same app as BOT4)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must match a Redirect URI in the Discord Developer Portal
DISCORD_REDIRECT_URI=https://your-render-service.onrender.com/callback

# Optional: where /connect should send users back after success
POST_SUCCESS_REDIRECT=

# Relay to your bot via Discord webhook (recommended)
DISCORD_RELAY_WEBHOOK_URL=
RELAY_PREFIX=CONNECTION_DATA

# Shared secret used to sign relay messages (set the same value in the bot as BOT4_RELAY_HMAC_SECRET)
RELAY_HMAC_SECRET=

